# Cookie Lab API deployment environment
# Copy this file to .env in your host and fill real values.

PORT=5050
COOKIE_LAB_SECRET=
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=240
METRICS_ENABLED=true
SERVER_REQUEST_TIMEOUT_MS=15000
SERVER_HEADERS_TIMEOUT_MS=20000
SERVER_KEEPALIVE_TIMEOUT_MS=5000

# Owner auth (optional)
OWNER_USER=owner
OWNER_PASS=owner123

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_TIMEOUT_MS=5000
STRIPE_MAX_NETWORK_RETRIES=3

# Braintree
BT_ENVIRONMENT=sandbox
BT_MERCHANT_ID=
BT_PUBLIC_KEY=
BT_PRIVATE_KEY=
BT_MERCHANT_ACCOUNT_ID=
BT_DEFAULT_SUBMIT_FOR_SETTLEMENT=false

# PayPal REST
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Commerce Layer (Braintree Payments API)
CL_API_BASE=
CL_ACCESS_TOKEN=
